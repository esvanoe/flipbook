# Server Configuration
SERVER_PORT=58082
SERVER_HOST=0.0.0.0
SERVER_BODY_LIMIT=19922944

# Admin Configuration
ADMIN_ALLOWED_IPS=127.0.0.1,::1
ADMIN_SOCKET_KEY=your-secure-random-key-here-minimum-32-characters-long
JWT_SECRET=your-jwt-secret-here-minimum-32-characters-long

# Browser Configuration
BROWSER_MAX_INSTANCES=10
BROWSER_MIN_POOL_SIZE=2
BROWSER_IDLE_TIMEOUT=300000
BROWSER_USER_DATA_PATH=./user_data
BROWSER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
BROWSER_PROXY=

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=

